# PostgreSQL (e.g. Neon)
# Use the full connection string from your host (Neon: include ?sslmode=require).
# After creating the DB, run once: npx prisma db push
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Optional vision for POST /api/parse/lineup and /api/parse/schedule
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# auto | openai | claude
VISION_PROVIDER=auto
# Default in code is claude-sonnet-4-6 if unset (older ids like claude-3-5-sonnet-20241022 are retired).
# ANTHROPIC_MODEL=claude-sonnet-4-6

SETLISTFM_API_KEY=
# Spotify: client credentials (track search) + one OAuth callback for “Add playlist in Spotify”
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Exact URL in Spotify app settings → e.g. http://localhost:3000/api/spotify/callback
SPOTIFY_REDIRECT_URI=
# Optional: fallback only. OAuth uses the request Host / x-forwarded-* so the redirect
# matches the tab (same as localStorage). Set this if a rare deploy has no host headers.
# NEXT_PUBLIC_APP_URL=
# For signing OAuth state; optional if you reuse the client secret
SPOTIFY_STATE_SECRET=
