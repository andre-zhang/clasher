# PostgreSQL (e.g. Neon)
# Use the full connection string from your host (Neon: include ?sslmode=require).
# After creating the DB, run once: npx prisma db push
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Optional vision for POST /api/parse/lineup and /api/parse/schedule
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# auto | openai | claude
VISION_PROVIDER=auto
# Default in code is claude-sonnet-4-6 if unset (older ids like claude-3-5-sonnet-20241022 are retired).
# ANTHROPIC_MODEL=claude-sonnet-4-6

SETLISTFM_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
